{
  "version": 8,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 28,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "template",
      "hidden": true,
      "cacheVariables": {
        "ENABLE_FRONTEND_API": true,
        "ENABLE_QT": true
      }
    },
    {
      "name": "windows-x64",
      "displayName": "Windows x64",
      "inherits": [
        "template"
      ],
      "binaryDir": "${sourceDir}/build_x64",
      "generator": "Visual Studio 17 2022",
      "architecture": "x64",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      },
      "cacheVariables": {
        "CMAKE_SYSTEM_VERSION": "10.0.22621.0"
      }
    },
    {
      "name": "windows-ci-x64",
      "inherits": [
        "windows-x64"
      ],
      "cacheVariables": {
        "CMAKE_COMPILE_WARNING_AS_ERROR": true,
        "ENABLE_WHISPER_CUDA": true
      }
    },
    {
      "name": "macos",
      "inherits": [
        "template"
      ],
      "binaryDir": "${sourceDir}/build_macos",
      "generator": "Xcode",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Darwin"
      },
      "cacheVariables": {
        "CMAKE_OSX_DEPLOYMENT_TARGET": "12.0",
        "CMAKE_OSX_ARCHITECTURES": "arm64"
      }
    },
    {
      "name": "macos-ci",
      "inherits": [
        "macos"
      ],
      "cacheVariables": {
        "CMAKE_COMPILE_WARNING_AS_ERROR": false
      }
    },
    {
      "name": "ubuntu-x86_64",
      "inherits": [
        "template"
      ],
      "binaryDir": "${sourceDir}/build_x86_64",
      "generator": "Ninja",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      },
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo"
      }
    },
    {
      "name": "ubuntu-ci-x86_64",
      "inherits": [
        "ubuntu-x86_64"
      ],
      "cacheVariables": {
        "CMAKE_COMPILE_WARNING_AS_ERROR": true,
        "ENABLE_WHISPER_CUDA": true
      }
    },
    {
      "name": "windows-ninja-cuda-x64",
      "displayName": "Windows Ninja CUDA x64",
      "inherits": [
        "template"
      ],
      "binaryDir": "${sourceDir}/build_cuda",
      "generator": "Ninja",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      },
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_SYSTEM_VERSION": "10.0.26100.0",
        "ENABLE_WHISPER_CUDA": true,
        "CMAKE_COMPILE_WARNING_AS_ERROR": false,
        "CMAKE_EXPORT_COMPILE_COMMANDS": true,
        "CMAKE_SUPPRESS_REGENERATION": true,
        "CLIP_CROPPER_USE_LLAMA_CPP": "ON",
        "CLIP_CROPPER_LLAMA_CPP_DIR": "${sourceDir}/deps/llama.cpp"
      }
    },
    {
      "name": "ubuntu-ninja-cuda-x86_64",
      "inherits": [
        "ubuntu-x86_64"
      ],
      "cacheVariables": {
        "ENABLE_WHISPER_CUDA": true,
        "CMAKE_COMPILE_WARNING_AS_ERROR": false,
        "CMAKE_EXPORT_COMPILE_COMMANDS": true
      }
    },
    {
      "name": "windows-ninja-cuda-x64-static-deps",
      "displayName": "Windows Ninja CUDA x64 Static Deps",
      "inherits": "windows-ninja-cuda-x64",
      "binaryDir": "${sourceDir}/build_cuda_static_deps",
      "cacheVariables": {
        "BUILD_SHARED_LIBS": "OFF",

        "ENABLE_WHISPER_CUDA": "ON",
        "GGML_CUDA": "ON",
        "GGML_BACKEND_DL": "OFF",
        "GGML_NATIVE": "OFF",
        "CMAKE_CUDA_ARCHITECTURES": "86",

        "CMAKE_COMPILE_WARNING_AS_ERROR": "OFF",

        "CLIP_CROPPER_STATIC_DEPS": "ON",
        "CLIP_CROPPER_USE_LLAMA_CPP": "ON",
        "CLIP_CROPPER_LLAMA_CPP_DIR": "${sourceDir}/deps/llama.cpp",

        "CLIP_CROPPER_STATIC_CUDA_RUNTIME": "ON",
        "CMAKE_CUDA_RUNTIME_LIBRARY": "Static",

        "CLIP_CROPPER_STATIC_QT": "OFF",
        "CLIP_CROPPER_DEPLOY_QT_RUNTIME": "ON",
        "CLIP_CROPPER_STATIC_MSVC_RUNTIME": "OFF",

        "VCPKG_TARGET_TRIPLET": "x64-windows-static-md"
      }
    },
    {
      "name": "windows-ninja-cuda-x64-static-qt",
      "inherits": "windows-ninja-cuda-x64-static-deps",
      "cacheVariables": {
        "CLIP_CROPPER_STATIC_QT": "ON",
        "CMAKE_PREFIX_PATH": "C:/Qt/6.6.2/msvc2022_64_static",
        "Qt6_DIR": "C:/Qt/6.6.2/msvc2022_64_static/lib/cmake/Qt6"
      }
    },
    {
      "name": "windows-ninja-cuda-x64-static-deps-mt",
      "inherits": "windows-ninja-cuda-x64-static-deps",
      "cacheVariables": {
        "CLIP_CROPPER_STATIC_MSVC_RUNTIME": "ON",
        "CMAKE_MSVC_RUNTIME_LIBRARY": "MultiThreaded$<$<CONFIG:Debug>:Debug>",
        "VCPKG_TARGET_TRIPLET": "x64-windows-static"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "windows-ninja-cuda-x64",
      "configurePreset": "windows-ninja-cuda-x64"
    },
    {
      "name": "windows-ci-x64",
      "configurePreset": "windows-ci-x64",
      "configuration": "RelWithDebInfo"
    },
    {
      "name": "macos-ci",
      "configurePreset": "macos-ci",
      "configuration": "RelWithDebInfo"
    },
    {
      "name": "ubuntu-ci-x86_64",
      "configurePreset": "ubuntu-ci-x86_64",
      "configuration": "RelWithDebInfo"
    },
    {
      "name": "ubuntu-ninja-cuda-x86_64",
      "configurePreset": "ubuntu-ninja-cuda-x86_64"
    },
    {
      "name": "windows-ninja-cuda-x64-static-deps",
      "displayName": "Build Windows Ninja CUDA x64 Static Deps",
      "configurePreset": "windows-ninja-cuda-x64-static-deps",
      "configuration": "RelWithDebInfo"
    }
  ]
}
